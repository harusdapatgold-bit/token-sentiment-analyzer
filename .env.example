# LLM provider — OpenAI-compatible endpoint.
# MiMo is used LIGHTLY for synthesis briefs only (~500-800 tokens per run).
# All scoring is deterministic (lexicon + onchain metrics).
LLM_BASE_URL=https://platform.xiaomimimo.com/v1
LLM_API_KEY=***
LLM_MODEL=mimo-v2.5-flagship

# Optional — CryptoPanic API for social signal aggregation.
# Free tier: 50 req/day. Leave empty to use built-in lexicon only.
CRYPTOPANIC_TOKEN=

# Database path (SQLite)
DB_PATH=data/sentiment.sqlite

# Reports output directory
REPORTS_DIR=data/reports
